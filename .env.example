# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the orchestrator (bypasses RLS). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Used by db/migrate.ts to apply db/migrations/*.sql (direct Postgres connection string).
# Find it in Supabase: Project Settings -> Database -> Connection string (URI).
SUPABASE_DB_URL=

# ---- LLM (Anthropic Claude) ----
ANTHROPIC_API_KEY=
# Default model id for generation/verification (see project claude-api reference).
ANTHROPIC_MODEL=claude-opus-4-8

# ---- App ----
APP_BASE_URL=http://localhost:3000

# ---- Cost guardrails (DECISIONS.md D3) ----
AUDIT_COST_BUDGET_USD=2.00
AUDIT_COST_HARD_CAP_USD=3.50

# ---- Analytics & Tracking runtime capture (Phase 1.1) ----
# "true" enables headless/rendered network capture; "false" keeps runtime-only
# tags Unknown/Unverified (graceful fallback).
ANALYTICS_RENDER_ENABLED=false
RENDER_TIMEOUT_MS=12000
# Optional: path to a local Chromium/Chrome executable. If unset, system Chrome
# (channel "chrome") is used locally; on Vercel @sparticuz/chromium is used.
PLAYWRIGHT_CHROMIUM_PATH=
